<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <include file="$(find-pkg-share foxglove_bridge)/launch/foxglove_bridge_launch.xml">
    <arg name="port" value="8765"/>
  </include>

  <node pkg="v4l2_camera" exec="v4l2_camera_node" name="gopro" output="screen"
    namespace="gopro">
    <param name="video_device" value="/dev/video2"/>
    <param name="image_size" value="[1920,1080]"/>
    <param name="pixel_format" value="YUYV"/>
    <param name="time_per_frame" value="[1,60]"/>
    <param name="image_raw.enable_pub_plugins"
           value="['image_transport/raw', 'image_transport/compressed']"/>
  </node>

  <node pkg="polyumi_ros2" exec="pi_receiver_node" 
    name="pi_receiver" output="screen" namespace="pi">
  </node>

</launch>